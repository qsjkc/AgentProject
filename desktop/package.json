{
  "name": "detachym-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5174 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5174 electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win nsis",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^26.0.12",
    "vite": "^5.4.8",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.detachym.desktop",
    "productName": "Detachym",
    "artifactName": "DetachymAgentPet1.0.${ext}",
    "asar": true,
    "directories": {
      "output": "dist/releases"
    },
    "files": [
      "electron/**/*",
      "build/icon.ico",
      "build/icon.png",
      "dist/renderer/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
